config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Ketsu"
run/main_scene="uid://c35ekx8l4seuy"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

Events="*res://scenes/events.gd"
DialogueManager="*res://addons/dialogue_manager/dialogue_manager.gd"
Playerdata="*res://scenes/playerdata.gd"
Hitstop="*res://hitstop.gd"
State="*res://state.gd"
RoomManager="*res://RoomManager.gd"
Combatmusicmanager="*res://combatmusicmanager.gd"
Fade="*uid://c222o0gifa4c"
ShopMusic="*uid://bdl0b7dt8fbvc"
MainMusic="*uid://dsj7xonbmg0rn"
Respawn="*uid://b2afk81ctiucf"
AudioSettings="*uid://cn7s756ep5vbv"
MusicRouter="*uid://d386ki8yu87da"

[dialogue_manager]

runtime/balloon_path="res://dialogue/balloon.tscn"

[display]

